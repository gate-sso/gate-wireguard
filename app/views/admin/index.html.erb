<% content_for :title, "Dashboard" %>

<div class="page-header">
  <div>
    <h3>Dashboard</h3>
    <div class="page-header-subtitle"><%= @current_user.name %> @ gate-wireguard</div>
  </div>
</div>

<% if @current_user.admin? %>
  <div class="row g-3 mb-4" data-controller="device-status" data-device-status-url-value="<%= admin_device_status_path %>" data-device-status-interval-value="30000">
    <div class="col-sm-3">
      <div class="card stat-card">
        <div class="stat-value text-primary"><%= User.count %></div>
        <div class="stat-label">users</div>
      </div>
    </div>
    <div class="col-sm-3">
      <div class="card stat-card">
        <div class="stat-value text-success"><%= VpnDevice.count %></div>
        <div class="stat-label">devices</div>
      </div>
    </div>
    <div class="col-sm-3">
      <div class="card stat-card">
        <div class="stat-value text-info"><%= VpnDevice.where(node: true).count %></div>
        <div class="stat-label">nodes</div>
      </div>
    </div>
    <div class="col-sm-3">
      <div class="card stat-card">
        <div class="stat-value" style="color: var(--color-accent);" id="online-count"><%= @online_count %></div>
        <div class="stat-label">online</div>
      </div>
    </div>
  </div>

  <div class="card p-4 mb-4">
    <h6 class="mb-3 font-mono text-muted" style="font-size: 0.8rem; letter-spacing: 0.05em;">QUICK ACTIONS</h6>
    <div class="d-flex flex-wrap gap-2">
      <a href="/admin/users" class="btn btn-outline-primary btn-sm"><i class="bi bi-people"></i> Users</a>
      <a href="/vpn_devices" class="btn btn-outline-primary btn-sm"><i class="bi bi-router"></i> Devices</a>
      <a href="/vpn_devices?nodes=true" class="btn btn-outline-primary btn-sm"><i class="bi bi-diagram-3"></i> Nodes</a>
      <a href="/admin/vpn_configurations" class="btn btn-outline-primary btn-sm"><i class="bi bi-gear"></i> Config</a>
      <a href="/admin/backups" class="btn btn-outline-primary btn-sm"><i class="bi bi-shield-check"></i> Backup</a>
      <a href="/api_keys" class="btn btn-outline-primary btn-sm"><i class="bi bi-key"></i> API Keys</a>
    </div>
  </div>

  <% if @device_statuses&.any? %>
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 font-mono" style="font-size: 0.8rem; letter-spacing: 0.05em;">PEER STATUS</h6>
        <%= link_to new_vpn_device_path, class: "btn btn-primary btn-sm" do %><i class="bi bi-plus-lg"></i> Add Device<% end %>
      </div>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead>
            <tr>
              <th></th>
              <th>Device</th>
              <th>IP</th>
              <th>Endpoint</th>
              <th>Last Seen</th>
              <th>RX / TX</th>
              <th>Traffic</th>
            </tr>
          </thead>
          <tbody>
            <% @device_statuses.each do |device| %>
              <tr data-device-id="<%= device[:id] %>">
                <td><span class="status-dot <%= device[:online] ? 'online' : 'offline' %>" title="<%= device[:online] ? 'Online' : 'Offline' %>"></span></td>
                <td>
                  <span class="fw-semibold"><%= link_to device[:description], vpn_device_path(device[:id]), class: "link-body-emphasis link-offset-2 link-underline-opacity-0 link-underline-opacity-100-hover" %></span>
                  <% if device[:node] %><span class="badge bg-secondary ms-1">Node</span><% end %>
                </td>
                <td><code class="font-mono" style="font-size: 0.75rem;"><%= device[:ip] %></code></td>
                <td class="endpoint"><code class="font-mono" style="font-size: 0.7rem;"><%= device[:endpoint] || '-' %></code></td>
                <td class="last-seen font-mono" style="font-size: 0.75rem;"><%= device[:last_handshake_ago] || 'never' %></td>
                <td class="transfer font-mono" style="font-size: 0.7rem;">
                  <span class="text-info">↓ <%= number_to_human_size(device[:rx_bytes]) %></span> / 
                  <span class="text-success">↑ <%= number_to_human_size(device[:tx_bytes]) %></span>
                </td>
                <td><span class="sparkline" data-rx-history="[<%= device[:rx_bytes] %>]" data-tx-history="[<%= device[:tx_bytes] %>]"></span></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
<% end %>

<% if @current_user.vpn_devices.any? && !@current_user.admin? %>
  <div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Your Devices</h5>
      <%= link_to new_vpn_device_path, class: "btn btn-primary btn-sm" do %><i class="bi bi-plus-lg"></i> Add Device<% end %>
    </div>
    <div class="card-body p-0">
      <%= render 'vpn_devices/vpn_devices', vpn_devices: @current_user.vpn_devices %>
    </div>
  </div>
<% elsif !@current_user.admin? %>
  <div class="card">
    <div class="empty-state">
      <i class="bi bi-router text-muted"></i>
      <h5>No devices yet</h5>
      <p>Create your first VPN device to get started with secure network access.</p>
      <%= link_to new_vpn_device_path, class: "btn btn-primary" do %><i class="bi bi-plus-lg"></i> Add a Device<% end %>
    </div>
  </div>
<% end %>
