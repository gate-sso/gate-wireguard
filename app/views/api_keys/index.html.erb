<div class="page-header">
  <div>
    <h3>Your API Keys</h3>
    <div class="page-header-subtitle"><%= @api_keys.count %> keys</div>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <h5 class="card-title">Create API Key</h5>
    <p class="card-text text-muted small">Generate a key for external API access. Copy the token immediately — it will not be shown again.</p>
    <%= form_with(model: ApiKey.new, url: api_keys_path, class: 'd-flex gap-2') do |f| %>
      <%= f.text_field :name, placeholder: 'e.g. ClawStation Production', class: 'form-control', required: true, style: 'max-width: 350px;' %>
      <%= f.submit 'Create Key', class: 'btn btn-primary' %>
    <% end %>
  </div>
</div>

<% if flash[:raw_token] %>
  <div class="alert alert-warning alert-dismissible fade show">
    <strong><i class="bi bi-exclamation-triangle"></i> New API Token (copy now!)</strong>
    <code class="d-block mt-2 p-2 bg-dark text-light rounded" style="word-break: break-all;"><%= flash[:raw_token] %></code>
    <small class="text-muted">This token will not be shown again.</small>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead>
        <tr>
          <th>Name</th>
          <th>Status</th>
          <th>Last Used</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @api_keys.each do |key| %>
          <tr>
            <td><%= key.name %></td>
            <td>
              <% if key.active? %>
                <span class="badge bg-success">Active</span>
              <% else %>
                <span class="badge bg-danger">Revoked</span>
              <% end %>
            </td>
            <td><%= key.last_used_at&.strftime('%Y-%m-%d %H:%M') || 'Never' %></td>
            <td><%= key.created_at.strftime('%Y-%m-%d %H:%M') %></td>
            <td>
              <% if key.active? %>
                <%= button_to api_key_path(key), method: :delete, class: 'btn btn-sm btn-outline-danger',
                    data: { turbo_confirm: 'Revoke this API key?' } do %>
                  Revoke
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
