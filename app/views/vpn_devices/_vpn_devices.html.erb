<% vpn_devices_require_updates = vpn_devices.select { |d| d.description.blank? } %>

<% if vpn_devices_require_updates.any? %>
  <div class="p-3">
    <div class="alert alert-warning mb-3">
      <i class="bi bi-exclamation-triangle me-2"></i>
      Please add a description to the following device(s). Devices without a description cannot have configurations.
    </div>
    <% vpn_devices_require_updates.each do |vpn_device| %>
      <%= form_with model: vpn_device, class: "mb-3" do |form| %>
        <div class="row g-2 align-items-center">
          <div class="col-md-4">
            <%= form.text_field :description, class: "form-control", placeholder: "Device Description" %>
          </div>
          <div class="col-md-3">
            <%= form.text_field :private_key, class: "form-control font-mono", disabled: true, placeholder: "Private Key" %>
          </div>
          <div class="col-md-2">
            <% if @current_user.admin %>
              <div class="form-check">
                <%= form.check_box(:node, class: "form-check-input") %>
                <label class="form-check-label">Infra node?</label>
              </div>
            <% end %>
          </div>
          <div class="col-md-3 d-flex gap-2">
            <%= form.submit "Update", class: "btn btn-primary btn-sm" %>
            <%= link_to vpn_device, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm" do %>
              Remove
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>

<% if vpn_devices_require_updates.empty? %>
  <div class="p-3">
    <%= button_to vpn_devices_path, class: "btn btn-primary btn-sm" do %>
      <i class="bi bi-plus-lg"></i> Add a VPN Device
    <% end %>
  </div>
<% end %>

<% vpn_devices.select(&:description?).each do |vpn_device| %>
  <div class="device-item" <%= "data-controller=qr-code data-qr-code-url-value=#{vpn_device_qr_code_path(vpn_device)}".html_safe unless vpn_device.node %>>
    <div class="device-item-header">
      <div class="d-flex align-items-center gap-2">
        <i class="bi bi-phone<%= vpn_device.node ? '-fill' : '' %> device-icon"></i>
        <div>
          <span class="fw-semibold"><%= vpn_device.description %></span>
          <% if vpn_device.node %>
            <span class="badge bg-secondary ms-1">Node</span>
          <% end %>
        </div>
      </div>
      <div class="d-flex gap-1">
        <%= link_to download_config_path(vpn_device.id), class: "btn btn-outline-primary btn-sm", title: "Download config" do %>
          <i class="bi bi-download"></i>
        <% end %>
        <% unless vpn_device.node %>
          <button class="btn btn-outline-secondary btn-sm"
                  data-action="click->qr-code#open"
                  title="Show QR code">
            <i class="bi bi-qr-code"></i>
          </button>
          <%= link_to vpn_device, method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm", title: "Remove device" do %>
            <i class="bi bi-trash3"></i>
          <% end %>
        <% end %>
      </div>
    </div>
    <div class="device-item-body">
      <div class="device-detail">
        <span class="device-detail-label">IP</span>
        <code><%= vpn_device.ip_allocation.ip_address %></code>
      </div>
      <div class="device-detail">
        <span class="device-detail-label">Public Key</span>
        <code class="font-mono text-truncate" style="max-width: 260px; font-size: 0.75rem;"><%= vpn_device.public_key %></code>
      </div>
      <div class="device-detail">
        <span class="device-detail-label">Networks</span>
        <span class="text-muted"><%= @vpn_configuration.network_addresses.map(&:network_address).join(", ") %></span>
      </div>
    </div>
  </div>
<% end %>
