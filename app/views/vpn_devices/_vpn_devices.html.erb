<% vpn_devices.select(&:description?).each do |vpn_device| %>
  <div class="device-item" <%= "data-controller=qr-code data-qr-code-url-value=#{vpn_device_qr_code_path(vpn_device)}".html_safe unless vpn_device.node %>>
    <div class="device-item-header">
      <div class="d-flex align-items-center gap-2">
        <i class="bi bi-phone<%= vpn_device.node ? '-fill' : '' %> device-icon"></i>
        <div>
          <span class="fw-semibold"><%= vpn_device.description %></span>
          <% if vpn_device.node %>
            <span class="badge bg-secondary ms-1">Node</span>
          <% end %>
        </div>
      </div>
      <div class="d-flex gap-1">
        <% if @current_user&.admin? %>
          <button class="btn btn-outline-secondary btn-sm"
                  data-bs-toggle="collapse"
                  data-bs-target="#edit-device-<%= vpn_device.id %>"
                  title="Edit device">
            <i class="bi bi-pencil"></i>
          </button>
        <% end %>
        <%= link_to download_config_path(vpn_device.id), class: "btn btn-outline-primary btn-sm", title: "Download config" do %>
          <i class="bi bi-download"></i>
        <% end %>
        <% unless vpn_device.node %>
          <button class="btn btn-outline-secondary btn-sm"
                  data-action="click->qr-code#open"
                  title="Show QR code">
            <i class="bi bi-qr-code"></i>
          </button>
        <% end %>
        <%= link_to vpn_device, method: :delete, data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm", title: "Remove device" do %>
          <i class="bi bi-trash3"></i>
        <% end %>
      </div>
    </div>
    <% if @current_user&.admin? %>
      <div class="collapse" id="edit-device-<%= vpn_device.id %>">
        <div class="p-3 border-top bg-light" data-controller="served-networks">
          <%= form_with model: vpn_device, class: "row g-2 align-items-start" do |form| %>
            <div class="col-md-3">
              <label class="form-label small">Description</label>
              <%= form.text_field :description, class: "form-control form-control-sm" %>
            </div>
            <div class="col-md-2">
              <div class="form-check mt-4">
                <%= form.check_box :node, class: "form-check-input",
                                   data: { served_networks_target: "nodeCheckbox", action: "change->served-networks#toggle" } %>
                <label class="form-check-label small">Infra node?</label>
              </div>
            </div>
            <div class="col-md-4 d-none" data-served-networks-target="container">
              <label class="form-label small">Served Networks</label>
              <div data-served-networks-target="list">
                <% vpn_device.served_networks_list.each do |cidr| %>
                  <div class="input-group input-group-sm mb-1">
                    <input type="text" class="form-control font-mono" style="font-size: 0.7rem;" value="<%= cidr %>"
                           data-served-networks-target="entry" data-action="input->served-networks#sync">
                    <button type="button" class="btn btn-outline-danger" data-action="click->served-networks#remove">
                      <i class="bi bi-x-lg" style="font-size: 0.6rem;"></i>
                    </button>
                  </div>
                <% end %>
              </div>
              <button type="button" class="btn btn-outline-secondary btn-xs" style="font-size: 0.65rem; padding: 0.1rem 0.4rem;" data-action="click->served-networks#add">
                <i class="bi bi-plus-lg"></i> Add CIDR
              </button>
              <%= form.hidden_field :served_networks, data: { served_networks_target: "hidden" } %>
              <template data-served-networks-target="template">
                <div class="input-group input-group-sm mb-1">
                  <input type="text" class="form-control font-mono" style="font-size: 0.7rem;" placeholder="10.0.0.0/8"
                         data-served-networks-target="entry" data-action="input->served-networks#sync">
                  <button type="button" class="btn btn-outline-danger" data-action="click->served-networks#remove">
                    <i class="bi bi-x-lg" style="font-size: 0.6rem;"></i>
                  </button>
                </div>
              </template>
            </div>
            <div class="col-md-3 d-flex gap-2 mt-4 justify-content-end">
              <%= form.submit "Save", class: "btn btn-primary btn-sm" %>
              <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="collapse" data-bs-target="#edit-device-<%= vpn_device.id %>">Cancel</button>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
    <div class="device-item-body">
      <div class="device-detail">
        <span class="device-detail-label">IP</span>
        <code><%= vpn_device.ip_allocation&.ip_address %></code>
      </div>
      <div class="device-detail">
        <span class="device-detail-label">Public Key</span>
        <code class="font-mono text-truncate" style="max-width: 260px; font-size: 0.75rem;"><%= vpn_device.public_key %></code>
      </div>
      <div class="device-detail">
        <span class="device-detail-label">Networks</span>
        <span class="text-muted"><%= @vpn_configuration&.network_addresses&.map(&:network_address)&.join(", ") %></span>
      </div>
      <% if vpn_device.node? && vpn_device.served_networks_list.any? %>
        <div class="device-detail">
          <span class="device-detail-label">Served Networks</span>
          <span class="text-muted"><%= vpn_device.served_networks_list.join(", ") %></span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
